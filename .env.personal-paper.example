# Copy to .env.personal-paper.local for your private local paper-trading profile.
# Do not commit the local file. The startup scripts force local Postgres/Redis/CORS.

APP_ENV=development
AUTH_REQUIRE_LOGIN=true
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change-me-admin
AUTH_TRADER_USERNAME=trader
AUTH_TRADER_PASSWORD=change-me-trader

BROKER_MODE=alpaca_paper
ALLOW_LIVE_TRADING=false
ALLOW_CONTROLLER_MOCK=false

ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

DEFAULT_ACCOUNT_EQUITY=100000
DEFAULT_RISK_PCT=1
MAX_POSITION_NOTIONAL_PCT=100
DAILY_LOSS_LIMIT_PCT=2
MAX_OPEN_POSITIONS=6
