APP_ENV=development
APP_DEFAULT_ROLE=admin
APP_ALLOW_ROLE_OVERRIDE=true
OPS_REQUIRE_AUTH=false
AUTH_REQUIRE_LOGIN=true
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_NAME=traders_cockpit_session
AUTH_DB_PATH=./data/auth.db
AUTH_SEED_USERS=true
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=admin123!
AUTH_TRADER_USERNAME=trader
AUTH_TRADER_PASSWORD=trader123!

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8010/ws/cockpit
CORS_ORIGINS=http://127.0.0.1:3010,http://localhost:3010

DATABASE_URL=postgresql://traders_cockpit:traders_cockpit@127.0.0.1:55432/traders_cockpit
REDIS_URL=redis://127.0.0.1:56379/0
REDIS_CHANNEL_PREFIX=traders-cockpit
ALLOW_SQLITE_FALLBACK=false
SQLITE_FALLBACK_URL=sqlite:///./data/traders_cockpit.db

BROKER_MODE=paper
ALLOW_LIVE_TRADING=false
ALLOW_CONTROLLER_MOCK=true
LIVE_CONFIRMATION_TOKEN=

ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_API_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

MASSIVE_API_KEY=
MASSIVE_API_BASE_URL=https://api.polygon.io
POLYGON_API_KEY=
POLYGON_API_BASE_URL=https://api.polygon.io

DEFAULT_ACCOUNT_EQUITY=100000
DEFAULT_RISK_PCT=1
MAX_POSITION_NOTIONAL_PCT=100
DAILY_LOSS_LIMIT_PCT=2
MAX_OPEN_POSITIONS=6

OPS_API_KEY=
OPS_ADMIN_API_KEY=
OPS_SIGNING_SECRET=
